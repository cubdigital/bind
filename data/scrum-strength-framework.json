  "coachingPrinciples": [
    {
      "title": "Train Positions Not Just Muscles",
      "description": "Scrum performance is highly angle dependent."
    },
    {
      "title": "Use Isometrics",
      "description": "Scrums involve large amounts of static force production and stiffness."
    },
    {
      "title": "Train Under Fatigue",
      "description": "Body position deteriorates under fatigue, so training should simulate this."
    },
    {
      "title": "Progress Neck Training Carefully",
      "description": "Avoid excessive loading progression too quickly."
    },
    {
      "title": "Prioritize Horizontal Force",
      "description": "Sleds and scrum-specific force vectors matter more than purely vertical gym strength."
    }
  ],
